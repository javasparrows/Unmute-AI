generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== Enums =====

enum Plan {
  FREE
  PRO
  MAX
}

enum UserRole {
  USER
  ADMIN
}

enum PlanChangeSource {
  STRIPE_WEBHOOK
  ADMIN_OVERRIDE
  BACKFILL
}

enum AdminActionType {
  ROLE_CHANGE
  PLAN_OVERRIDE_SET
  PLAN_OVERRIDE_CLEAR
  SOFT_DELETE
  RESTORE
}

// ===== Auth.js required tables =====

model User {
  id                   String         @id @default(cuid())
  name                 String?
  email                String         @unique
  emailVerified        DateTime?
  image                String?
  accounts             Account[]
  sessions             Session[]
  documents            Document[]
  usageRecords         UsageRecord[]
  apiUsageLogs         ApiUsageLog[]
  feedbacks            UserFeedback[]
  role                 UserRole       @default(USER)
  plan                 Plan           @default(FREE)
  planOverride         Plan?          // 管理者手動付与（NULL=無効、設定時はStripeより優先）
  planOverrideNote     String?        // 付与理由 e.g. "開発者", "友人招待"
  stripeCustomerId     String?        @unique
  stripeSubscriptionId String?        @unique
  stripePriceId        String?
  subscriptionStatus   String?        // "active", "canceled", "past_due"
  currentPeriodEnd     DateTime?
  hasSeenWelcome       Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime?      @updatedAt
  deletedAt            DateTime?
  deletedById          String?
  deletedByUser        User?          @relation("UserDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedUsers         User[]         @relation("UserDeletedBy")
  pageViews            PageView[]
  planChanges          PlanChangeLog[]
  loginDevices         LoginDevice[]
  adminActionsPerformed AdminActionLog[] @relation("AdminActionActor")
  adminActionsReceived  AdminActionLog[] @relation("AdminActionTarget")
  writingSessions      WritingSession[]
  achievements         Achievement[]
  literatureWatches    LiteratureWatch[]

  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===== Application tables =====

model Document {
  id                   String               @id @default(cuid())
  title                String               @default("無題の翻訳")
  userId               String
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions             DocumentVersion[]
  manuscriptCitations  ManuscriptCitation[]
  manuscriptClaims     ManuscriptClaim[]
  agentRuns            AgentRun[]
  reviewFindings       ReviewFinding[]
  evidenceMappings     EvidenceMapping[]
  paragraphAnalyses    ParagraphAnalysis[]
  journey              PaperJourney?
  complianceReports    ComplianceReport[]
  milestones           DocumentMilestone[]
  writingSessions      WritingSession[]
  submissionPlan       SubmissionPlan?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([userId])
}

model DocumentVersion {
  id             String   @id @default(cuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber  Int
  sourceText     String   @db.Text
  translatedText String   @db.Text
  sourceLang     String
  targetLang     String
  journal        String?
  provider       String?
  leftRanges          Json?
  rightRanges         Json?
  sentenceAlignments  Json?
  sections            Json?             // DocumentSectionMeta: section boundaries
  createdAt           DateTime @default(now())

  @@unique([documentId, versionNumber])
  @@index([documentId])
}

model UsageRecord {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month            String   // "2026-02" format
  translationChars Int      @default(0)
  structureChecks  Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
}

model ApiUsageLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String   // "translation" | "structure_check"
  model           String   // e.g. "gemini-2.5-flash"
  inputTokens     Int
  outputTokens    Int
  sourceChars     Int      @default(0)
  translatedChars Int      @default(0)
  sourceLang      String?
  targetLang      String?
  documentId      String?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, type])
}

model PageView {
  id          String   @id @default(cuid())
  visitorId   String
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  path        String
  locale      String?
  countryCode String?  @db.VarChar(2)
  createdAt   DateTime @default(now())

  @@index([path, createdAt, visitorId])
  @@index([visitorId, createdAt])
  @@index([userId, createdAt])
  @@index([countryCode, createdAt])
}

model PageViewDaily {
  id             String   @id @default(cuid())
  date           DateTime @db.Date
  path           String
  locale         String   @default("")
  countryCode    String   @default("") @db.VarChar(2)
  views          Int
  uniqueVisitors Int
  createdAt      DateTime @default(now())

  @@unique([date, path, locale, countryCode])
  @@index([date])
  @@index([path, date])
}

model LoginDevice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceHash  String   // hash of user-agent + IP for fingerprinting
  userAgent   String?  @db.Text
  ip          String?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([userId, deviceHash])
  @@index([userId])
}

model PlanChangeLog {
  id                   String           @id @default(cuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromPlan             Plan
  toPlan               Plan
  source               PlanChangeSource
  externalEventId      String?          @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  note                 String?          @db.Text
  createdAt            DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([toPlan, createdAt])
  @@index([source, createdAt])
}

model AdminActionLog {
  id           String          @id @default(cuid())
  actorId      String
  actor        User            @relation("AdminActionActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUserId String
  targetUser   User            @relation("AdminActionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  action       AdminActionType
  reason       String?
  before       Json?
  after        Json?
  createdAt    DateTime        @default(now())

  @@index([createdAt])
  @@index([targetUserId])
}

// ===== Citation Evidence System =====

model CanonicalPaper {
  id              String            @id @default(cuid())
  title           String
  abstract        String?           @db.Text
  authors         Json?             // [{name: string, affiliations?: string[]}]
  year            Int?
  venue           String?
  citationCount   Int               @default(0)
  influentialCount Int              @default(0)
  fieldsOfStudy   String[]
  isRetracted     Boolean           @default(false)
  retractionNote  String?           @db.Text
  lastCheckedAt   DateTime?
  orcids          String[]
  rorIds          String[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  identifiers     PaperIdentifier[]
  snapshots       ProviderSnapshot[]
  relations       PaperRelation[]   @relation("fromPaper")
  relatedTo       PaperRelation[]   @relation("toPaper")
  evidenceSnippets EvidenceSnippet[]
  claimCards      ClaimCard[]
  manuscriptCitations ManuscriptCitation[]
  pdfCache        PdfCache?
}

model PaperIdentifier {
  id          String          @id @default(cuid())
  paperId     String
  provider    String          // "openalex" | "semantic_scholar" | "crossref" | "pubmed" | "arxiv"
  externalId  String
  paper       CanonicalPaper  @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([paperId])
}

model ProviderSnapshot {
  id          String          @id @default(cuid())
  paperId     String
  provider    String
  data        Json
  fetchedAt   DateTime        @default(now())
  paper       CanonicalPaper  @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
}

model PaperRelation {
  id          String          @id @default(cuid())
  fromPaperId String
  toPaperId   String
  type        String          // "cites" | "cited_by" | "related"
  fromPaper   CanonicalPaper  @relation("fromPaper", fields: [fromPaperId], references: [id], onDelete: Cascade)
  toPaper     CanonicalPaper  @relation("toPaper", fields: [toPaperId], references: [id], onDelete: Cascade)

  @@unique([fromPaperId, toPaperId, type])
  @@index([fromPaperId])
  @@index([toPaperId])
}

model EvidenceSnippet {
  id            String          @id @default(cuid())
  paperId       String
  sourceType    String          // "FULLTEXT" | "ABSTRACT"
  sectionLabel  String?
  text          String          @db.Text
  charStart     Int?
  charEnd       Int?
  provenanceUrl String?
  createdAt     DateTime        @default(now())
  paper         CanonicalPaper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  claimCardEvidence ClaimCardEvidence[]

  @@index([paperId])
}

model ClaimCard {
  id              String          @id @default(cuid())
  paperId         String
  subject         String
  relation        String
  object          String
  qualifiers      Json            @default("{}")
  polarity        String          @default("positive") // "positive" | "negative" | "neutral"
  supportLabel    String          // "SUPPORTED" | "PARTIAL" | "CONTRADICTED" | "INSUFFICIENT"
  evidenceTier    String          // "FULLTEXT" | "ABSTRACT_ONLY"
  confidence      Float
  createdAt       DateTime        @default(now())
  paper           CanonicalPaper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  evidence        ClaimCardEvidence[]
  manuscriptSupports ManuscriptClaimSupport[]

  @@index([paperId])
  @@index([confidence])
}

model ClaimCardEvidence {
  id              String          @id @default(cuid())
  claimCardId     String
  snippetId       String
  claimCard       ClaimCard       @relation(fields: [claimCardId], references: [id], onDelete: Cascade)
  snippet         EvidenceSnippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([claimCardId, snippetId])
}

model ManuscriptCitation {
  id          String          @id @default(cuid())
  documentId  String
  paperId     String
  sectionType String?         // "INTRODUCTION" | "METHODS" | "RESULTS" | "DISCUSSION"
  citeKey     String?         // e.g., "smith2024"
  createdAt   DateTime        @default(now())
  document    Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  paper       CanonicalPaper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  anchors     ManuscriptCitationAnchor[]
  evidenceMappings EvidenceMapping[]

  @@unique([documentId, paperId])
  @@index([documentId])
}

model ManuscriptCitationAnchor {
  id                    String              @id @default(cuid())
  manuscriptCitationId  String
  sectionType           String              // "INTRODUCTION" | "METHODS" | "RESULTS" | "DISCUSSION"
  sentenceIndex         Int
  charStart             Int?
  charEnd               Int?
  createdAt             DateTime            @default(now())
  manuscriptCitation    ManuscriptCitation   @relation(fields: [manuscriptCitationId], references: [id], onDelete: Cascade)

  @@index([manuscriptCitationId])
}

model ManuscriptClaim {
  id            String          @id @default(cuid())
  documentId    String
  sectionType   String
  sentenceIndex Int
  claimText     String          @db.Text
  createdAt     DateTime        @default(now())
  document      Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  supports      ManuscriptClaimSupport[]

  @@index([documentId])
}

model ManuscriptClaimSupport {
  id              String          @id @default(cuid())
  manuscriptClaimId String
  claimCardId     String
  manuscriptClaim ManuscriptClaim @relation(fields: [manuscriptClaimId], references: [id], onDelete: Cascade)
  claimCard       ClaimCard       @relation(fields: [claimCardId], references: [id], onDelete: Cascade)

  @@unique([manuscriptClaimId, claimCardId])
}

model AgentRun {
  id          String          @id @default(cuid())
  documentId  String?
  agentType   String          // "discovery" | "verification" | "writing" | "review"
  status      String          @default("pending") // "pending" | "running" | "completed" | "failed"
  input       Json
  output      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  document    Document?       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([status])
}

model ReviewFinding {
  id              String          @id @default(cuid())
  documentId      String
  severity        String          // "BLOCKER" | "MAJOR" | "MINOR"
  type            String          // "UNSUPPORTED" | "MISATTRIBUTED" | "MISSING_KEY_PAPER" | "LOGIC_GAP" | "STYLE"
  targetSentenceId String?
  explanation     String          @db.Text
  suggestedFix    String?         @db.Text
  resolved        Boolean         @default(false)
  createdAt       DateTime        @default(now())
  document        Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model UserFeedback {
  id          String          @id @default(cuid())
  userId      String
  paperId     String?
  feedbackType String         // "relevance" | "reject" | "manual_citation"
  data        Json
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===== Evidence Mapping System (v2) =====

model EvidenceMapping {
  id                    String   @id @default(cuid())
  documentId            String
  manuscriptCitationId  String
  manuscriptSentence    String   @db.Text
  sentenceIndex         Int
  sectionType           String?

  supportingPassage     String   @db.Text
  citedPaperSection     String?
  citedPaperPage        Int?
  confidence            Float
  mappingRationale      String?  @db.Text

  screenshotUrl         String?
  screenshotCoords      Json?

  humanVerified         Boolean  @default(false)
  verifiedBy            String?
  verifiedAt            DateTime?
  verificationNote      String?  @db.Text
  verificationStatus    String   @default("pending")

  document              Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  manuscriptCitation    ManuscriptCitation  @relation(fields: [manuscriptCitationId], references: [id], onDelete: Cascade)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([documentId, manuscriptCitationId, sentenceIndex])
  @@index([documentId])
  @@index([manuscriptCitationId])
  @@index([documentId, verificationStatus])
}

model PdfCache {
  id          String   @id @default(cuid())
  paperId     String   @unique
  doi         String?
  pdfUrl      String
  storedPath  String
  pageCount   Int?
  fileSize    Int?
  parsedText  Json?
  status      String   @default("pending")
  failReason  String?

  paper       CanonicalPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model ParagraphAnalysis {
  id              String   @id @default(cuid())
  documentId      String
  versionNumber   Int
  sectionType     String?

  analysis        Json
  overallScore    Int?
  issueCount      Int      @default(0)

  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@index([documentId])
  @@index([documentId, sectionType])
}

// ===== Guided Workflow System =====

model PaperJourney {
  id              String   @id @default(cuid())
  documentId      String   @unique
  currentPhase    Int      @default(1)
  currentTask     String   @default("1.1")
  phaseStatuses   Json     @default("{}")  // { "1": "in_progress", "2": "not_started", ... }
  taskStatuses    Json     @default("{}")  // { "1.1": "completed", "1.2": "in_progress", ... }
  guideVisible    Boolean  @default(true)

  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  taskCompletions TaskCompletion[]

  startedAt       DateTime @default(now())
  lastActivityAt  DateTime @default(now()) @updatedAt

  @@index([documentId])
}

model TaskCompletion {
  id              String   @id @default(cuid())
  journeyId       String
  taskId          String   // e.g., "2.1"
  status          String   @default("not_started") // not_started | in_progress | completed | skipped
  autoCompleted   Boolean  @default(false)
  completedAt     DateTime?
  skippedReason   String?
  metadata        Json?    // snapshot at completion time

  journey         PaperJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([journeyId, taskId])
  @@index([journeyId])
}

// ===== Guideline Compliance System =====

model ComplianceReport {
  id              String   @id @default(cuid())
  documentId      String
  guidelineId     String                   // "CONSORT-AI" | "TRIPOD-AI" | "CLAIM" | "STARD-AI" | "GAMER"
  results         Json                     // ComplianceResult[]
  metCount        Int      @default(0)
  totalCount      Int      @default(0)
  score           Int?                     // 0-100 percentage

  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@index([documentId])
  @@index([documentId, guidelineId])
}

// ===== Productivity Layer =====

model DocumentMilestone {
  id          String   @id @default(cuid())
  documentId  String
  title       String
  description String?  @db.Text
  type        String   @default("CUSTOM")  // DRAFT_COMPLETE | CITATIONS_DONE | REVIEW_DONE | SUBMISSION_READY | CUSTOM
  targetDate  DateTime
  completedAt DateTime?
  status      String   @default("NOT_STARTED")  // NOT_STARTED | IN_PROGRESS | COMPLETED
  sortOrder   Int      @default(0)

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([documentId])
  @@index([documentId, status])
}

model WritingSession {
  id            String   @id @default(cuid())
  userId        String
  documentId    String
  status        String   @default("ACTIVE")  // ACTIVE | PAUSED | COMPLETED | ABANDONED

  startedAt     DateTime @default(now())
  endedAt       DateTime?
  totalPausedMs Int      @default(0)

  wordsAtStart  Int      @default(0)
  wordsAtEnd    Int?
  wordsWritten  Int?
  citationsAdded Int     @default(0)

  pomodoroCount  Int     @default(0)
  pomodoroLength Int     @default(25)
  breakLength    Int     @default(5)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([documentId])
  @@index([userId, startedAt])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String   // FIRST_DOCUMENT | FIRST_CITATION | FIRST_EVIDENCE | FIRST_EXPORT | WRITING_STREAK | WORDS_MILESTONE | POMODORO_MILESTONE
  documentId  String?
  metadata    Json?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievedAt  DateTime @default(now())

  @@unique([userId, type])
  @@index([userId])
}

model LiteratureWatch {
  id          String   @id @default(cuid())
  userId      String
  topic       String
  query       String                    // Search query for OpenAlex/S2
  enabled     Boolean  @default(true)
  frequency   String   @default("weekly")  // daily | weekly
  lastChecked DateTime?
  results     Json?                     // Latest results snapshot

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, enabled])
}

model SubmissionPlan {
  id              String   @id @default(cuid())
  documentId      String   @unique
  targetJournal   String?
  targetDate      DateTime?
  coverLetter     String?  @db.Text
  checklist       Json     @default("[]")  // SubmissionCheckItem[]
  reviewerCandidates Json  @default("[]")  // ReviewerCandidate[]
  notes           String?  @db.Text

  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([documentId])
}
